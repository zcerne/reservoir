{
    "resolution": 20,
    "run_until": 200,
    "snapshot_t1": 170,
    "snapshot_t2": 178,
    "snapshot_dt": 2,
    "dimention": 3,
    "cell_size_y": 14.0,
    "cell_size_z": 14.0,
    "periodic": false,
    "pml_size": 2.0,
    "background_index": 1.0,

    "object_order": [
        "guide_1",
        "reservoir",
        "guide_2",
        "source_1",
        "flux_1",
        "flux_2",
        "monitor_1",
        "monitor_2"
    ],

    "guide_1": {
        "class": "guide",
        "index": 1.0,
        "sizes": [2.0, 10.0]
    },

    "reservoir": {
        "class": "reservoir",
        "sizes": [50, 10, 10],
        "resolution": 10,
        "boundary_conditions": ["free", "free", "free"],
        "face_phi":   [null, null, null, null, null, null],
        "face_theta": [null, null, null, null, null, null],
        "ignore_faces": [false, false, false, false, false, false],
        "elastic_constants": {
            "K1": 11.1,
            "K2": 6.5,
            "K3": 17.1,
            "q0": 0.0
        },
        "n_o": 1.52,
        "n_e": 1.71,
        "S": 1.0,
        "maxeval": 2000,
        "f_tolerance": 1e-6,
        "optimize_phi_theta": [true, true],
        "boundary_function": "perlin_3d",
        "boundary_scale": 2.0,
        "boundary_seed": 42,
        "boundary_same_opposite": [true, true, true]
    },

    "guide_2": {
        "class": "guide",
        "index": 1.0,
        "sizes": [2.0, 10.0]
    },

    "source_1": {
        "class": "source",
        "position": {
            "on_object": "guide_1",
            "position": "center",
            "size": [10.0, 10.0]
        },
        "amplitude": 1.0,
        "component": "Ey",
        "source_type": "continuous",
        "lam": 0.532,
        "dlam": 0.0
    },

    "flux_1": {
        "class": "monitor",
        "type": "flux",
        "on_object": "guide_1",
        "position": {"position": "right", "size": 10.0},
        "lam_range": [0.532, 0.532],
        "n_lam": 1
    },

    "flux_2": {
        "class": "monitor",
        "type": "flux",
        "on_object": "guide_2",
        "position": {"position": "left", "size": 10.0},
        "lam_range": [0.532, 0.532],
        "n_lam": 1
    },

    "monitor_1": {
        "class": "monitor",
        "type": "2Ddft",
        "on_object": "guide_1",
        "position": {"position": "right", "size": 10.0},
        "lam_range": [0.532, 0.532],
        "n_lam": 1
    },

    "monitor_2": {
        "class": "monitor",
        "type": "2Ddft",
        "on_object": "guide_2",
        "position": {"position": "left", "size": 10.0},
        "lam_range": [0.532, 0.532],
        "n_lam": 1
    },

    "_options": {
        "snapshot_t1/t2/dt": "windowed snapshots: record every dt from t1 to t2",
        "snapshot_time": "legacy uniform snapshots every dt from t=0",
        "sizes": "2-element [sx, sy] = 2D LC; 3-element [sx, sy, sz] = 3D LC",
        "optimize_phi_theta": "[opt_phi, opt_theta] booleans",
        "boundary_conditions": "per-axis [x, y, z]: 'free' | 'periodic'",
        "face_phi": "6-tuple (x_min, x_max, y_min, y_max, z_min, z_max): float (rad) = pin, null = free",
        "face_theta": "6-tuple same order",
        "boundary_function": "null | 'random' (2D) | 'random_3d' (all 6 faces, white noise) | 'perlin_3d' (all 6 faces, smooth Gaussian noise, scale=2µm default)",
        "boundary_seed": "integer seed (null = random each run)",
        "ignore_faces": "6-element bool list (x_min,x_max,y_min,y_max,z_min,z_max): true = free face (overrides boundary_function on that face)",
        "source_type": "'continuous' | 'gaussian' | 'flattop'",
        "component": "'Ex' | 'Ey' | 'Ez' | 'Hx' | 'Hy' | 'Hz'",
        "monitor_type": "'flux' | '0Ddft' | '1Ddft' | '2Ddft' | '3Ddft' | '0Dsnap' | '1Dsnap' | '2Dsnap' | '3Dsnap'"
    }
}
